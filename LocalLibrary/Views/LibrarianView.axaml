<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalLibrary.ViewModels"
             xmlns:m="using:LocalLibrary.Models"
             xmlns:views="using:LocalLibrary.Views"
             x:Class="LocalLibrary.Views.LibrarianView"
             x:DataType="vm:LibrarianViewModel">

    <StackPanel Margin="10" Spacing="10">

        <views:LogoutButtonView DataContext="{Binding}"/>

        <!-- Título -->
        <TextBlock Text="Library Catalog"
                   FontSize="20"
                   HorizontalAlignment="Center"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Watermark="Search by title, author, or ISBN"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1" Content="Clear" Command="{Binding ClearSearchCommand}"/>
        </Grid>

        <!-- Lista de libros -->
        <TextBlock Text="{Binding EmptyStateMessage}"
               IsVisible="{Binding ShowEmptyState}"
               Foreground="#666666"/>
        <ListBox x:Name="BooksListBox"
                 ItemsSource="{Binding FilteredBooks}"
                 SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                 Height="200"
                 x:DataType="vm:LibrarianViewModel">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Book">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Title}" Width="150"/>
                        <TextBlock Text="{Binding Author}" Width="150"/>
                        <TextBlock Text="{Binding ISBN}" Width="100"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Edit Selected Book"
           FontSize="16"
           Margin="0,10,0,0"/>

        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
        <TextBox Grid.Column="0"
             Watermark="Title"
             Text="{Binding SelectedBook.Title, Mode=TwoWay}"/>

         <TextBox Grid.Column="1"
             Watermark="Author"
             Text="{Binding SelectedBook.Author, Mode=TwoWay}"/>

         <TextBox Grid.Column="2"
             Watermark="ISBN"
             Text="{Binding SelectedBook.ISBN, Mode=TwoWay}"/>
        </Grid>

        <TextBox Watermark="Description"
             Text="{Binding SelectedBook.Description, Mode=TwoWay}"
             AcceptsReturn="True"
             Height="70"
             TextWrapping="Wrap"/>

<Button Content="Save Changes"
    Command="{Binding EditSelectedBookCommand}"/>

        <!-- Formulario para agregar -->
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <TextBox Grid.Column="0" Watermark="Title" Text="{Binding NewBookTitle, Mode=TwoWay}" />
            <TextBox Grid.Column="1" Watermark="Author" Text="{Binding NewBookAuthor, Mode=TwoWay}" />
            <TextBox Grid.Column="2" Watermark="ISBN" Text="{Binding NewBookIsbn, Mode=TwoWay}" />
        </Grid>

        <TextBox
                 Watermark="Description"
                 Text="{Binding NewBookDescription, Mode=TwoWay}"
                 AcceptsReturn="True"
                 Height="70"
                 TextWrapping="Wrap"/>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" Spacing="10">

            <Button Content="Add Book" Command="{Binding AddBookCommand}"/>
            <Button Content="Delete Book" Command="{Binding DeleteSelectedBookCommand}"/>

        </StackPanel>

        <TextBlock x:Name="StatusTextBlock"
                   Text="{Binding StatusMessage}"
                   Foreground="{Binding StatusColor}"
                   TextWrapping="Wrap"/>

        <TextBlock Text="Active Loans"
           FontSize="16"
           Margin="0,10,0,0"/>

<ListBox ItemsSource="{Binding Loans}" Height="150">
    <ListBox.ItemTemplate>
        <DataTemplate x:DataType="m:Loan">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding BookTitle}" Width="180"/>
                <TextBlock Text="{Binding BookISBN}" Width="120"/>
                <TextBlock Text="{Binding MemberName}" Width="120"/>
                <TextBlock Text="{Binding BorrowDate}" Width="150"/>
            </StackPanel>
        </DataTemplate>
    </ListBox.ItemTemplate>
</ListBox>

    </StackPanel>

</UserControl>