<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LocalLibrary.ViewModels"
             xmlns:m="using:LocalLibrary.Models"
             xmlns:views="using:LocalLibrary.Views"
             x:Class="LocalLibrary.Views.LibrarianView"
             x:DataType="vm:LibrarianViewModel">

    <StackPanel Margin="10" Spacing="10">

        <views:LogoutButtonView DataContext="{Binding}"/>

        <!-- Título -->
        <TextBlock Text="Library Catalog"
                   FontSize="20"
                   HorizontalAlignment="Center"/>

        <!-- Lista de libros -->
        <ListBox x:Name="BooksListBox"
                 ItemsSource="{Binding Books}"
                 SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                 Height="200"
                 x:DataType="vm:LibrarianViewModel">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Book">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Title}" Width="150"/>
                        <TextBlock Text="{Binding Author}" Width="150"/>
                        <TextBlock Text="{Binding ISBN}" Width="100"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Formulario para agregar -->
        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
            <TextBox x:Name="TitleTextBox" Grid.Column="0" Watermark="Title" />
            <TextBox x:Name="AuthorTextBox" Grid.Column="1" Watermark="Author" />
            <TextBox x:Name="IsbnTextBox" Grid.Column="2" Watermark="ISBN" />
        </Grid>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal" Spacing="10">

            <Button Content="Add Book" Click="AddBook_Click"/>
            <Button Content="Delete Book" Click="DeleteBook_Click"/>

        </StackPanel>

        <TextBlock x:Name="StatusTextBlock"
                   Text=""
                   Foreground="Green"
                   TextWrapping="Wrap"/>

    </StackPanel>

</UserControl>