<UserControl xmlns="https://github.com/avaloniaui"
						 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
						 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
						 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
						 xmlns:vm="using:LocalLibrary.ViewModels"
						 xmlns:views="using:LocalLibrary.Views"
						 mc:Ignorable="d"
						 d:DesignWidth="1000"
						 d:DesignHeight="620"
						 x:Class="LocalLibrary.Views.MemberView"
						 x:DataType="vm:MemberViewModel">

	<Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Margin="12">
		<Grid ColumnDefinitions="*,Auto">
			<StackPanel Grid.Column="0">
			<TextBlock Text="Member Portal" FontSize="26" FontWeight="Bold" />
			<TextBlock Text="{Binding MemberName, StringFormat='Logged in as: {0}'}" />
			</StackPanel>
			<views:LogoutButtonView Grid.Column="1" DataContext="{Binding}"/>
		</Grid>

		<TabControl Grid.Row="1">
			<TabItem Header="Library Catalog">
				<views:CatalogView DataContext="{Binding Catalog}" />
			</TabItem>

			<TabItem Header="My Loans">
				<Grid RowDefinitions="*,Auto,Auto,Auto" RowSpacing="10" Margin="8">
					<Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6" Padding="8">
						<ListBox ItemsSource="{Binding MyLoans}"
										 SelectedItem="{Binding SelectedLoan, Mode=TwoWay}">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Margin="0,0,0,8">
										<TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
										<TextBlock Text="{Binding Author, StringFormat='Author: {0}'}" />
										<TextBlock Text="{Binding ISBN, StringFormat='ISBN: {0}'}" />
										<TextBlock Text="{Binding AverageRating, StringFormat='Average Rating: {0:F1}/5.0'}" />
										<TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Border>

					<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
						<Button Content="Return Selected" Command="{Binding ReturnSelectedLoanCommand}" />
						<Button Content="Refresh Loans" Command="{Binding RefreshLoansCommand}" />
					</StackPanel>

					<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
						<TextBlock Text="Rate selected:" VerticalAlignment="Center" />
						<Button Content="1" Command="{Binding RateSelectedLoanCommand}" CommandParameter="1" />
						<Button Content="2" Command="{Binding RateSelectedLoanCommand}" CommandParameter="2" />
						<Button Content="3" Command="{Binding RateSelectedLoanCommand}" CommandParameter="3" />
						<Button Content="4" Command="{Binding RateSelectedLoanCommand}" CommandParameter="4" />
						<Button Content="5" Command="{Binding RateSelectedLoanCommand}" CommandParameter="5" />
						<TextBlock Text="{Binding MyRatingText}" VerticalAlignment="Center" Margin="12,0,0,0" />
					</StackPanel>

					<TextBlock Grid.Row="3" Text="{Binding StatusMessage}" />
				</Grid>
			</TabItem>
		</TabControl>

		<TextBlock Grid.Row="2" Text="Use the Catalog tab to borrow available books." Foreground="#666666" />
	</Grid>
</UserControl>
